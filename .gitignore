# Environment variables — never commit secrets
.env
.env.*
*.env

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Virtual environments
venv/
env/
.venv/
ENV/

# Database files — runtime data, not source
db/*.db
db/*.sqlite
db/*.sqlite3

# Streamlit cache
.streamlit/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Build artifacts
dist/
build/
*.egg-info/
.eggs/

# Logs
*.log
logs/

# OS files
desktop.ini

# Incoming shipments — runtime data (PDFs uploaded by users, not source)
# Keep the folder itself tracked via incoming_shipments/.gitkeep
incoming_shipments/SHP-*/
processed_shipments/
